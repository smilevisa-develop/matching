generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Person {
  id              Int      @id @default(autoincrement())
  name            String
  photoUrl        String?
  driveFolderUrl  String?
  nationality     String
  department      String?
  residenceStatus String
  partnerId       Int?
  channel         String
  lineUserId      String?
  messengerPsid   String?
  email           String?
  whatsappId      String?
  /// 候補者を追加した担当者の表示名 (固定リストから 1 つ: トゥイ / チンディ / ミン / 土田)
  registeredBy    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages        Message[]
  onboarding      PersonOnboarding?
  documents       PortalDocument[]
  portalTasks     PortalTask[]
  resumeProfile   ResumeProfile?
  resumeDocuments ResumeDocument[]
  dealCandidates DealCandidate[]
  customQuestions PersonCustomQuestion[]
  placement      PersonPlacement?
  invoices       Invoice[]
  partner         Partner?  @relation(fields: [partnerId], references: [id], onDelete: SetNull)
}

model PersonCustomQuestion {
  id          Int      @id @default(autoincrement())
  personId    Int
  person      Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  label       String
  type        String   @default("text") // "text" or "file"
  required    Boolean  @default(false)
  answer      String?
  fileName    String?
  fileUrl     String?
  mimeType    String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([personId, sortOrder])
}

model Company {
  id           Int      @id @default(autoincrement())
  externalId   String?  @unique
  name         String
  industry     String?
  location     String?
  hiringStatus String   @default("募集中")
  driveFolderUrl String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  deals        Deal[]
}

model Partner {
  id            Int      @id @default(autoincrement())
  name          String
  country       String?
  channel       String?
  linkStatus    String   @default("未")
  contactName   String?
  notes         String?
  lineUserId    String?  @unique
  messengerPsid String?  @unique
  whatsappId    String?
  /// 1〜5 の評価 (☆ 5 段階)。null = 未評価
  rating        Int?
  /// 評価理由 (フリーテキスト)
  ratingReason  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  deals       Deal[]
  persons     Person[]
  groupMembers GroupMember[]
  invoices    Invoice[]
}

model StaffAccount {
  id                       Int                      @id @default(autoincrement())
  loginId                  String                   @unique
  name                     String
  role                     String                   @default("member")
  passcodeHash             String
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt

  sessions                 StaffSession[]
  appSettings              AppSettings?
  onboardingFormTemplates  OnboardingFormTemplate[]
  messageTemplates         MessageTemplate[]
  resumeTemplates          ResumeTemplate[]
  createdResumes           ResumeDocument[]
  ownedDeals               Deal[]
}

model StaffSession {
  id               Int          @id @default(autoincrement())
  accountId        Int
  token            String       @unique
  impersonatedById Int?
  expiresAt        DateTime
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  account          StaffAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model PersonOnboarding {
  id                       Int      @id @default(autoincrement())
  personId                 Int      @unique
  person                   Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  englishName              String?
  fullNameKana             String?
  birthDate                String?
  phoneNumber              String?
  postalCode               String?
  address                  String?
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyRelationship    String?
  status                   String   @default("draft")
  submittedAt              DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model PortalDocument {
  id              Int      @id @default(autoincrement())
  personId        Int
  person          Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  kind            String
  fileName        String
  fileUrl         String
  mimeType        String?
  autoJudgeStatus String   @default("pending")
  autoJudgeNote   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([personId, kind])
}

model PortalTask {
  id          Int       @id @default(autoincrement())
  personId    Int
  person      Person    @relation(fields: [personId], references: [id], onDelete: Cascade)
  type        String
  title       String
  description String?
  href        String?
  dueDate     DateTime?
  status      String    @default("pending")
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model LineProfile {
  id              Int      @id @default(autoincrement())
  lineUserId      String   @unique
  displayName     String?
  lastMessageText String?
  lastWebhookType String?
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MessengerProfile {
  id              Int      @id @default(autoincrement())
  psid            String   @unique
  lastMessageText String?
  lastWebhookType String?
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Message {
  id         Int       @id @default(autoincrement())
  personId   Int?
  person     Person?   @relation(fields: [personId], references: [id], onDelete: SetNull)
  channel    String
  direction  String
  content    String
  externalId String?
  sentAt     DateTime  @default(now())
  readAt     DateTime?
}

model MessageTemplate {
  id        Int      @id @default(autoincrement())
  accountId Int
  account   StaffAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ResumeTemplate {
  id               Int          @id @default(autoincrement())
  accountId        Int
  account          StaffAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name             String
  templateUrl      String
  driveFolderUrl   String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  resumeDocuments  ResumeDocument[]
}

model ResumeDocument {
  id               Int          @id @default(autoincrement())
  personId         Int
  person           Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  templateId       Int
  template         ResumeTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  accountId        Int
  account          StaffAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  title            String
  documentId       String?
  documentUrl      String?
  driveFolderUrl   String
  status           String       @default("draft")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model ResumeProfile {
  id              Int      @id @default(autoincrement())
  personId        Int      @unique
  person          Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  gender          String?
  country         String?
  spouseStatus    String?
  childrenCount   String?
  phoneHome       String?
  visaType        String?
  visaExpiryDate  String?
  workVisa        String?
  remarks         String?
  educations      Json?
  workExperiences Json?
  certifications  Json?
  motivation      String?
  selfIntroduction String?
  japanPurpose    String?
  currentJob      String?
  retirementReason String?
  preferenceNote  String?
  japaneseLevel   String?
  japaneseLevelDate String?
  licenseName     String?
  licenseExpiryDate String?
  otherQualificationName String?
  otherQualificationExpiryDate String?
  traineeExperience String?
  highSchoolName  String?
  highSchoolStartDate String?
  highSchoolEndDate String?
  universityName  String?
  universityStartDate String?
  universityEndDate String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AppSettings {
  id               Int          @id @default(autoincrement())
  accountId        Int          @unique
  account          StaffAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  calendarEmbedUrl String?
  calendarLabel    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CoreSettings {
  id                     Int      @id
  fixedQuestions         Json?
  // 推薦リスト出力で使うカラムキー (lib/recommendation-columns.ts の RECOMMENDATION_COLUMN_OPTIONS の key)
  recommendationColumns  Json?
  // 月ごとの目標 (内定数 / 売上)。後方互換のための既定値、新しい monthlyTargets が無い場合のフォールバック
  monthlyOfferTarget     Int?
  monthlyRevenueTarget   Int?
  // 月ごとの目標履歴。形式: [{ month: "2026-04", offer: 5, revenue: 1500000 }, ...]
  monthlyTargets         Json?
  // 推薦リスト用 Google Sheets テンプレ URL (列見出し + フォーマット込み)
  recommendationTemplateUrl String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model OnboardingFormTemplate {
  id          Int                      @id @default(autoincrement())
  accountId   Int
  account     StaffAccount             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name        String
  description String?
  questions   OnboardingFormQuestion[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
}

model OnboardingFormQuestion {
  id         Int                    @id @default(autoincrement())
  templateId Int
  template   OnboardingFormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fixedKey   String?
  label      String
  type       String
  required   Boolean                @default(false)
  sortOrder  Int                    @default(0)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@index([templateId, sortOrder])
}

model Group {
  id        Int           @id @default(autoincrement())
  name      String
  members   GroupMember[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model GroupMember {
  id       Int    @id @default(autoincrement())
  group    Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId  Int
  partner  Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId Int

  @@unique([groupId, partnerId])
}

model Deal {
  id           Int          @id @default(autoincrement())
  title        String
  companyId    Int
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  partnerId    Int?
  partner      Partner?     @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  ownerId      Int?
  owner        StaffAccount? @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  field        String?
  priority     String       @default("normal")
  status       String       @default("募集中")
  unitPrice    String?
  deadline     DateTime?
  acceptedAt   DateTime?
  requiredCount    Int      @default(0)
  recommendedCount Int      @default(0)
  interviewCount   Int      @default(0)
  offerCount       Int      @default(0)
  contractCount    Int      @default(0) // 旧: 成約 (UI 上は廃止、データは互換維持)
  declineCount     Int      @default(0) // 内定辞退
  rejectCount      Int      @default(0) // 不合格
  notes        String?
  /// 求人票の元になる条件 (Json: ExtractedJobPosting と同じキー集合)
  /// AI 取り込み / ChatGPT 貼り付け / 手動入力のいずれかで埋め、
  /// ここから 求人票 (JobPosting) を生成する
  conditions   Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  candidates   DealCandidate[]
  invoices     Invoice[]
  jobPostings  JobPosting[]
}

model JobPostingTemplate {
  id              Int      @id @default(autoincrement())
  name            String
  templateUrl     String
  driveFolderUrl  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  documents       JobPosting[]
}

model JobPosting {
  id                  Int      @id @default(autoincrement())
  dealId              Int
  deal                Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  templateId          Int?
  template            JobPostingTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  title               String
  documentId          String?
  documentUrl         String?
  driveFolderUrl      String?
  status              String   @default("draft")
  // 仕事内容
  jobDescription      String?
  workLocation        String?
  nearestStation      String?
  headcount           String?
  gender              String?
  nationality         String?
  // 勤務
  workTime1Start      String?
  workTime1End        String?
  workTime2Start      String?
  workTime2End        String?
  overtime            String?
  avgMonthlyOvertime  String?
  fixedOvertimeHours  String?
  fixedOvertimePay    String?
  // 給与
  monthlyGross        String?
  basicSalary         String?
  salaryCalcMethod    String?
  perfectAttendance   String?
  housingAllowance    String?
  nightShiftAllowance String?
  commuteAllowance    String?
  // 控除
  socialInsurance     String?
  employmentInsurance String?
  healthInsurance     String?
  pensionInsurance    String?
  incomeTax           String?
  residentTax         String?
  // 生活
  mealProvision       String?
  mealAmount          String?
  dormProvision       String?
  dormAmount          String?
  utilitiesProvision  String?
  utilitiesAmount     String?
  // その他
  holidays            String?
  otherBenefits       String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([dealId])
}

model PersonPlacement {
  id                    Int      @id @default(autoincrement())
  personId              Int      @unique
  person                Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  stage                 String?
  acceptedAt            DateTime?
  preInterviewAt        DateTime?
  companyInterviewAt    DateTime?
  offerAt               DateTime?
  offerAcceptedAt       DateTime?
  applicationPlannedAt  DateTime?
  applicationAt         DateTime?
  applicationResultAt   DateTime?
  applicationType       String?
  applicantName         String?
  returnHomeFlag        String?
  returnHomeAt          DateTime?
  entryPlannedAt        DateTime?
  entryAt               DateTime?
  joinPlannedAt         DateTime?
  joinAt                DateTime?
  sixMonthStatus        String?
  consultation          String?
  currentAction         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Invoice {
  id              Int      @id @default(autoincrement())
  personId        Int
  person          Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  dealId          Int?
  deal            Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  unitPrice       String?
  invoiceDate     DateTime?
  invoiceAmount   String?
  invoiceNumber   String?
  invoiceStatus   String   @default("未送付")
  invoiceUrl      String?
  channel         String   @default("自社") // "自社" or "PA"
  partnerId       Int?
  partner         Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull, map: "Invoice_partnerId_fkey")
  costAmount      String?
  paInvoiceUrl    String?
  paPaid          Boolean  @default(false)
  paPaidAt        DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([personId])
  @@index([dealId])
}

model DealCandidate {
  id          Int      @id @default(autoincrement())
  dealId      Int
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  personId    Int
  person      Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  stage       String   @default("new")
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([dealId, personId])
}

model MessageLog {
  id           Int       @id @default(autoincrement())
  title        String?
  body         String
  channel      String
  targetFilter String
  status       String
  matchedCount Int
  sentCount    Int
  skippedCount Int
  failedCount  Int       @default(0)
  recipients   Json?
  failures     Json?
  scheduledAt  DateTime?
  createdAt    DateTime  @default(now())
}
