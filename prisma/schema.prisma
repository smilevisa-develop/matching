generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Person {
  id              Int      @id @default(autoincrement())
  name            String
  photoUrl        String?
  driveFolderUrl  String?
  nationality     String
  department      String?
  residenceStatus String
  partnerId       Int?
  channel         String
  lineUserId      String?
  messengerPsid   String?
  email           String?
  whatsappId      String?
  /// 候補者を追加した担当者の表示名 (固定リストから 1 つ: トゥイ / チンディ / ミン / 土田)
  registeredBy    String?
  /// 候補者向け公開フォーム (intake) の共有トークン。SNS / LINE 等で URL を渡す
  intakeToken     String?  @unique
  /// 公開フォームの設定 (除外する質問キー / 個別追加質問)
  ///   形式: { excludedKeys: string[], customQuestions: [{ key, label, required, type }] }
  intakeConfig    Json?
  /// スプシ DB へ最後に反映した日時。
  /// この候補者 (本人 / onboarding / resumeProfile / 案件紐づけ) の updatedAt が
  /// これより新しいときだけスプシに書き込む。
  /// null = 一度も反映していない。既存候補者は移行時に現在時刻を入れて
  /// 「今後の変更だけ反映」する運用にしている。
  sheetSyncedAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages        Message[]
  onboarding      PersonOnboarding?
  documents       PortalDocument[]
  portalTasks     PortalTask[]
  resumeProfile   ResumeProfile?
  resumeDocuments ResumeDocument[]
  dealCandidates  DealCandidate[]
  customQuestions PersonCustomQuestion[]
  placement       PersonPlacement?
  invoices        Invoice[]
  partner         Partner?               @relation(fields: [partnerId], references: [id], onDelete: SetNull)
}

model PersonCustomQuestion {
  id        Int      @id @default(autoincrement())
  personId  Int
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  label     String
  type      String   @default("text") // "text" or "file"
  required  Boolean  @default(false)
  answer    String?
  fileName  String?
  fileUrl   String?
  mimeType  String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([personId, sortOrder])
}

model Company {
  id             Int      @id @default(autoincrement())
  externalId     String?  @unique
  name           String
  industry       String?
  location       String?
  hiringStatus   String   @default("募集中")
  driveFolderUrl String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  deals Deal[]
}

model Partner {
  id            Int     @id @default(autoincrement())
  name          String
  country       String?
  /// アクティブかどうか (非アクティブ = 一覧で折りたたみ非表示)
  isActive      Boolean @default(true)
  /// レガシー: 単一チャネル (後方互換用、preferredChannels に集約)
  channel       String?
  /// 一括送信で使う連絡手段の複数選択 (CSV: "LINE,mail,Messenger")。
  /// この Partner に一斉配信する際、ここに列挙された全チャネルに 同時 送信する。
  preferredChannels String?
  linkStatus    String  @default("未")
  contactName   String?
  contactPhone  String?
  notes         String?
  lineUserId    String? @unique
  messengerPsid String? @unique
  whatsappId    String?
  /// 1〜5 の評価 (☆ 5 段階)。null = 未評価
  rating        Int?
  /// 評価理由 (フリーテキスト)
  ratingReason  String?

  // --- スプシ「アライアンス先」由来のフィールド ---
  /// 役割: 求人 / 求職 / 求人・求職 / 学校 など
  role               String?
  /// 関係性 (実績有り/無し) — 後方互換用。relationshipStatus 由来の derived 値
  hasPerformance     Boolean @default(false)
  /// 関係性ラベル (実績有り / 実績無し / 有料 / 無料 / その他自由文字列)
  relationshipStatus String?
  /// メール
  email              String?
  /// SNS 連絡先 (URL or ID)
  snsContact         String?
  /// 特徴・強み (備考列)
  features           String?

  // --- 紹介可能 (checkbox 選択, CSV 保存) ---
  /// 紹介可能な国籍 (CSV: "ベトナム,インドネシア,...")
  introducibleNationalities     String?
  /// 国内 / 国外 / 両方
  introducibleScope             String?
  /// 紹介可能な分野 (CSV: "介護,外食,建設,...")
  introducibleFields            String?
  /// 紹介可能な在留資格 (CSV: "技能実習,特定技能1号,...")
  introducibleResidenceStatuses String?

  // --- 手数料 ---
  /// 目安の紹介手数料 (free text)
  feeAmount     String?
  /// 最低金額
  minFeeAmount  String?
  /// 配分比率
  feeShareRatio String?

  // ── Messenger Recurring Notifications (定期通知) ──
  /// Meta から発行される購読 token (これを使うと 24h 関係なく push 可)
  messengerSubscriptionToken     String?
  /// 購読頻度: "DAILY" | "WEEKLY" | "MONTHLY"
  messengerSubscriptionFrequency String?
  /// 購読開始日時
  messengerSubscribedAt          DateTime?
  /// 購読期限 (通常 6 ヶ月後)
  messengerSubscriptionExpiresAt DateTime?
  /// 購読状態: "ACTIVE" | "STOPPED" | "EXPIRED"
  messengerSubscriptionStatus    String?
  /// 購読トピック (例: 求人情報)
  messengerSubscriptionTopic     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals         Deal[]
  persons       Person[]
  groupMembers  GroupMember[]
  invoices      Invoice[]
  ratingHistory PartnerRatingHistory[]
  messages      Message[]
  lineGroups    LineGroup[]
  contacts      PartnerContact[]
}

/// パートナー会社の担当者 (1 社につき複数人を登録できる)
model PartnerContact {
  id        Int      @id @default(autoincrement())
  partnerId Int
  partner   Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  /// 担当者名
  name      String
  /// 役職 / 肩書き (任意)
  title     String?
  /// メール
  email     String?
  /// 電話番号
  phone     String?
  /// 補足メモ (使用言語、時差、得意分野など)
  notes     String?
  /// 並び順 (社内の主担当を先頭に等)
  sortOrder Int      @default(0)
  /// 主担当フラグ (1 パートナーにつき 1 人だけ true)。一斉配信の宛先として使う
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partnerId, sortOrder])
  @@index([partnerId, isPrimary])
}

model PartnerRatingHistory {
  id         Int      @id @default(autoincrement())
  partnerId  Int
  partner    Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  /// 1〜5 (null は手動でクリアした時点のレコード)
  rating     Int?
  reason     String?
  /// 記入者 (任意)
  recordedBy String?
  createdAt  DateTime @default(now())

  @@index([partnerId, createdAt])
}

model StaffAccount {
  id           Int      @id @default(autoincrement())
  loginId      String   @unique
  name         String
  role         String   @default("member")
  passcodeHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions                StaffSession[]
  appSettings             AppSettings?
  onboardingFormTemplates OnboardingFormTemplate[]
  messageTemplates        MessageTemplate[]
  resumeTemplates         ResumeTemplate[]
  createdResumes          ResumeDocument[]
  ownedDeals              Deal[]
}

model StaffSession {
  id               Int      @id @default(autoincrement())
  accountId        Int
  token            String   @unique
  impersonatedById Int?
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  account StaffAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model PersonOnboarding {
  id                    Int       @id @default(autoincrement())
  personId              Int       @unique
  person                Person    @relation(fields: [personId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  englishName           String?
  fullNameKana          String?
  birthDate             String?
  phoneNumber           String?
  postalCode            String?
  address               String?
  emergencyContactName  String?
  emergencyContactPhone String?
  emergencyRelationship String?
  status                String    @default("draft")
  submittedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model PortalDocument {
  id              Int      @id @default(autoincrement())
  personId        Int
  person          Person   @relation(fields: [personId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  kind            String
  fileName        String
  fileUrl         String
  mimeType        String?
  autoJudgeStatus String   @default("pending")
  autoJudgeNote   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([personId, kind])
}

model PortalTask {
  id          Int       @id @default(autoincrement())
  personId    Int
  person      Person    @relation(fields: [personId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  type        String
  title       String
  description String?
  href        String?
  dueDate     DateTime?
  status      String    @default("pending")
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model LineProfile {
  id              Int      @id @default(autoincrement())
  lineUserId      String   @unique
  displayName     String?
  lastMessageText String?
  lastWebhookType String?
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Bot が招待された LINE グループ / 複数人チャット
model LineGroup {
  id              Int      @id @default(autoincrement())
  /// LINE 側の group ID (グループ) or room ID (複数人チャット)
  groupId         String   @unique
  /// "group" or "room"
  sourceType      String   @default("group")
  /// グループ名 (LINE API で取得)
  groupName       String?
  /// グループメンバー数 (取得時のスナップショット)
  memberCount     Int?
  /// 紐づけ済みパートナー (nullable - 未紐づけ状態あり)
  partnerId       Int?
  partner         Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  /// 最終受信メッセージ本文
  lastMessageText String?
  /// 最終 webhook イベントタイプ
  lastWebhookType String?
  /// 最終アクセス日時
  lastSeenAt      DateTime @default(now())
  /// Bot がまだグループに在籍しているか (leave イベントで false に)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MessengerProfile {
  id              Int      @id @default(autoincrement())
  psid            String   @unique
  lastMessageText String?
  lastWebhookType String?
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WhatsappProfile {
  id              Int      @id @default(autoincrement())
  /// 国コード込みの WhatsApp 電話番号 (例: 81901234567)。WhatsApp Cloud API では これが宛先 ID
  waId            String   @unique
  profileName     String?
  lastMessageText String?
  lastWebhookType String?
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Message {
  id         Int       @id @default(autoincrement())
  personId   Int?
  person     Person?   @relation(fields: [personId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  /// パートナー宛/送信元メッセージ用 (person と排他、両方 null の場合は未紐づけ)
  partnerId  Int?
  partner    Partner?  @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  channel    String
  direction  String
  content    String
  externalId String?
  /// LINE グループ内の送信者の表示名 (グループメッセージの場合のみ。1:1 では null)
  senderName String?
  /// LINE グループ内の送信者の userId (内部識別用)
  senderId   String?
  sentAt     DateTime  @default(now())
  readAt     DateTime?
}

model MessageTemplate {
  id        Int          @id @default(autoincrement())
  accountId Int
  account   StaffAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name      String
  /// LINE / Messenger / 24h 内 WhatsApp 用の本文 ({{変数}} 含む)
  content   String

  /// メール送信時の件名 ({{変数}} 使用可)。空のときは共通デフォルト件名
  emailSubject String?

  // ── WhatsApp 承認済みテンプレートメッセージとして送る場合 ──
  /// Meta WhatsApp Business Manager で承認された テンプレ名 (例: partner_broadcast_v1)
  whatsappTemplateName   String?
  /// テンプレートの言語コード (例: ja, en, vi)
  whatsappTemplateLang   String?
  /// 本文 {{1}} {{2}} ... に渡す変数キーを順番で CSV 指定
  /// 例: "パートナー名,急ぎ案件一覧" → WhatsApp テンプレ本文の {{1}} = パートナー名展開後, {{2}} = 急ぎ案件一覧展開後
  whatsappTemplateParams String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ResumeTemplate {
  id             Int          @id @default(autoincrement())
  accountId      Int
  account        StaffAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name           String
  templateUrl    String
  driveFolderUrl String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  resumeDocuments ResumeDocument[]
}

model ResumeDocument {
  id             Int            @id @default(autoincrement())
  personId       Int
  person         Person         @relation(fields: [personId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  templateId     Int
  template       ResumeTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  accountId      Int
  account        StaffAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  title          String
  documentId     String?
  documentUrl    String?
  driveFolderUrl String
  status         String         @default("draft")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model ResumeProfile {
  id                           Int      @id @default(autoincrement())
  personId                     Int      @unique
  person                       Person   @relation(fields: [personId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  gender                       String?
  country                      String?
  spouseStatus                 String?
  childrenCount                String?
  phoneHome                    String?
  visaType                     String?
  visaExpiryDate               String?
  workVisa                     String?
  remarks                      String?
  educations                   Json?
  workExperiences              Json?
  certifications               Json?
  motivation                   String?
  selfIntroduction             String?
  japanPurpose                 String?
  currentJob                   String?
  retirementReason             String?
  preferenceNote               String?
  /// 履歴書 (元 PDF / docx / 画像) の Drive 上の直接 URL。
  /// bulk-add で履歴書をアップロードした際に保存される。推薦リスト出力時に
  /// 「履歴書 URL」列で使う。手作業で /personnel/[id]/edit から差し替え可能。
  resumeFileUrl                String?
  japaneseLevel                String?
  japaneseLevelDate            String?
  licenseName                  String?
  licenseExpiryDate            String?
  otherQualificationName       String?
  otherQualificationExpiryDate String?
  traineeExperience            String?
  highSchoolName               String?
  highSchoolStartDate          String?
  highSchoolEndDate            String?
  universityName               String?
  universityStartDate          String?
  universityEndDate            String?
  /// 事前質問 (面接前ヒアリング) の自由回答群。
  /// 形式: { questionKey: answer } の Json オブジェクト。
  /// 履歴書に出る項目 (志望動機/自己紹介/来日目的/現在の仕事/退職理由) は
  /// 専用カラムに直接入る。それ以外はここに格納する。
  interviewAnswers             Json?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

model AppSettings {
  id               Int          @id @default(autoincrement())
  accountId        Int          @unique
  account          StaffAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  calendarEmbedUrl String?
  calendarLabel    String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model CoreSettings {
  id                        Int      @id
  fixedQuestions            Json?
  // 推薦リスト出力で使うカラムキー (lib/recommendation-columns.ts の RECOMMENDATION_COLUMN_OPTIONS の key)
  recommendationColumns     Json?
  // 月ごとの目標 (内定数 / 売上)。後方互換のための既定値、新しい monthlyTargets が無い場合のフォールバック
  monthlyOfferTarget        Int?
  monthlyRevenueTarget      Int?
  // 月ごとの目標履歴。形式: [{ month: "2026-04", offer: 5, revenue: 1500000 }, ...]
  monthlyTargets            Json?
  // 推薦リスト用 Google Sheets テンプレ URL (列見出し + フォーマット込み)
  recommendationTemplateUrl String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model OnboardingFormTemplate {
  id          Int                      @id @default(autoincrement())
  accountId   Int
  account     StaffAccount             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name        String
  description String?
  questions   OnboardingFormQuestion[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
}

model OnboardingFormQuestion {
  id         Int                    @id @default(autoincrement())
  templateId Int
  template   OnboardingFormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fixedKey   String?
  label      String
  type       String
  required   Boolean                @default(false)
  sortOrder  Int                    @default(0)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@index([templateId, sortOrder])
}

model Group {
  id        Int           @id @default(autoincrement())
  name      String
  members   GroupMember[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model GroupMember {
  id        Int     @id @default(autoincrement())
  group     Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId   Int
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId Int

  @@unique([groupId, partnerId])
}

model Deal {
  id               Int           @id @default(autoincrement())
  title            String
  companyId        Int
  company          Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  partnerId        Int?
  partner          Partner?      @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  ownerId          Int?
  owner            StaffAccount? @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  field            String?
  priority         String        @default("normal")
  status           String        @default("募集中")
  unitPrice        String?
  deadline         DateTime?
  acceptedAt       DateTime?
  requiredCount    Int           @default(0)
  recommendedCount Int           @default(0)
  interviewCount   Int           @default(0)
  offerCount       Int           @default(0)
  contractCount    Int           @default(0) // 旧: 成約 (UI 上は廃止、データは互換維持)
  declineCount     Int           @default(0) // 内定辞退
  rejectCount      Int           @default(0) // 不合格
  notes            String?
  /// 求人票の元になる条件 (Json: ExtractedJobPosting と同じキー集合)
  /// AI 取り込み / ChatGPT 貼り付け / 手動入力のいずれかで埋め、
  /// ここから 求人票 (JobPosting) を生成する
  conditions       Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  candidates  DealCandidate[]
  invoices    Invoice[]
  jobPostings JobPosting[]
}

model JobPostingTemplate {
  id             Int      @id @default(autoincrement())
  name           String
  templateUrl    String
  driveFolderUrl String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  documents JobPosting[]
}

model JobPosting {
  id                  Int                 @id @default(autoincrement())
  dealId              Int
  deal                Deal                @relation(fields: [dealId], references: [id], onDelete: Cascade)
  templateId          Int?
  template            JobPostingTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  title               String
  documentId          String?
  documentUrl         String?
  driveFolderUrl      String?
  status              String              @default("draft")
  // 仕事内容
  jobDescription      String?
  workLocation        String?
  nearestStation      String?
  headcount           String?
  gender              String?
  nationality         String?
  // 勤務
  workTime1Start      String?
  workTime1End        String?
  workTime2Start      String?
  workTime2End        String?
  overtime            String?
  avgMonthlyOvertime  String?
  fixedOvertimeHours  String?
  fixedOvertimePay    String?
  // 給与
  monthlyGross        String?
  basicSalary         String?
  salaryCalcMethod    String?
  perfectAttendance   String?
  housingAllowance    String?
  nightShiftAllowance String?
  commuteAllowance    String?
  // 控除
  socialInsurance     String?
  employmentInsurance String?
  healthInsurance     String?
  pensionInsurance    String?
  incomeTax           String?
  residentTax         String?
  // 生活
  mealProvision       String?
  mealAmount          String?
  dormProvision       String?
  dormAmount          String?
  utilitiesProvision  String?
  utilitiesAmount     String?
  // その他
  holidays            String?
  otherBenefits       String?
  notes               String?
  // ── 新設 (2026-06 求人票テンプレ拡張) ──
  // 給与関連
  salaryIncrease         String? // 昇給有無
  bonus                  String? // 賞与有無
  salaryPayday           String? // 給与支払日
  salaryCutoff           String? // 給与締日
  monthlyDeduction       String? // 月控除額
  otherDeductions        String? // その他控除金額
  // 手当・生活費追加
  wifiFee                String? // Wifi代金額
  waterFee               String? // 水道代金額
  movingSupport          String? // 引越補助有無
  movingSupportDetails   String? // 引越補助詳細
  // 寮関連追加
  dormOccupants          String? // 寮人数
  bedroomShared          String? // 寝室共有
  dormCommuteTime        String? // 寮から通勤時間
  foodProvision          String? // 食事提供有無 (食費支給有無と別)
  // 募集条件
  foreignWorkers         String? // 外国人就業者
  overseasApplication    String? // 海外応募可否
  japaneseLevel          String? // 日本語レベル
  experienceYears        String? // 経験年数
  requiredQualifications String? // 必要資格
  commuteMethod          String? // 通勤手段
  // 選考関連
  preferredInterviewDate String? // 面接希望日
  selectionFlow          String? // 選考フロー
  preferredEntryDate     String? // 入国希望日
  // 勤務条件追加
  trialPeriod              String? // 試用期間有無
  trialPeriodDetails       String? // 試用期間詳細
  facilities               String? // 設備
  holidayCategory          String? // 休日休暇区分
  socialInsuranceCoverage  String? // 社会保険 (加入有無、料金は socialInsurance 列と別)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([dealId])
}

model PersonPlacement {
  id                   Int       @id @default(autoincrement())
  personId             Int       @unique
  person               Person    @relation(fields: [personId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  stage                String?
  acceptedAt           DateTime?
  preInterviewAt       DateTime?
  companyInterviewAt   DateTime?
  offerAt              DateTime?
  offerAcceptedAt      DateTime?
  applicationPlannedAt DateTime?
  applicationAt        DateTime?
  applicationResultAt  DateTime?
  applicationType      String?
  applicantName        String?
  returnHomeFlag       String?
  returnHomeAt         DateTime?
  entryPlannedAt       DateTime?
  entryAt              DateTime?
  joinPlannedAt        DateTime?
  joinAt               DateTime?
  sixMonthStatus       String?
  consultation         String?
  currentAction        String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Invoice {
  id            Int       @id @default(autoincrement())
  personId      Int
  person        Person    @relation(fields: [personId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  dealId        Int?
  deal          Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  unitPrice     String?
  invoiceDate   DateTime?
  invoiceAmount String?
  invoiceNumber String?
  invoiceStatus String    @default("未送付")
  invoiceUrl    String?
  channel       String    @default("自社") // "自社" or "PA"
  partnerId     Int?
  partner       Partner?  @relation(fields: [partnerId], references: [id], onDelete: SetNull, map: "Invoice_partnerId_fkey")
  costAmount    String?
  paInvoiceUrl  String?
  paPaid        Boolean   @default(false)
  paPaidAt      DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([personId])
  @@index([dealId])
}

model DealCandidate {
  id        Int      @id @default(autoincrement())
  dealId    Int
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  personId  Int
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  stage     String   @default("new")
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dealId, personId])
}

model MessageLog {
  id           Int       @id @default(autoincrement())
  title        String?
  body         String
  channel      String
  targetFilter String
  status       String
  matchedCount Int
  sentCount    Int
  skippedCount Int
  failedCount  Int       @default(0)
  recipients   Json?
  failures     Json?
  scheduledAt  DateTime?
  createdAt    DateTime  @default(now())
}

/// チャネル別 月次送信通数。
/// LINE フリープラン 200通/月 等の上限を画面で警告するため自前で集計する。
/// (LINE API は今月の利用通数を取得できない)
///
///   channel:   "LINE" | "Messenger" | "Email" | "WhatsApp"
///   yearMonth: "2026-06" 形式 (UTC ベース、月初切り替え)
///   messageCount: その月にこのチャネルで送ったメッセージ数 (画像枚数も含む)
///
/// LINE は "1 push の text + image 4枚 = 5 通" としてカウント (LINE 課金単位に合わせる)
model MonthlyChannelUsage {
  id            Int      @id @default(autoincrement())
  channel       String
  yearMonth     String
  messageCount  Int      @default(0)
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@unique([channel, yearMonth])
  @@index([yearMonth])
}

/// 一斉送信の画像添付など、システム生成 / 管理者アップロードファイル。
/// 画像 (JPG/PNG) のみ想定、最大 5MB。HTTPS で公開して LINE / Messenger の
/// originalContentUrl から参照できるようにする。
///
/// 注意: 公開アクセスだが、id は cuid(unguessable) で実質保護。
/// expiresAt 経過後は cron で物理削除する想定。
model UploadedFile {
  id                String    @id @default(cuid())
  filename          String
  mimeType          String
  sizeBytes         Int
  data              Bytes
  /// アップロードしたアカウント (将来監査用)。今は null 許容で運用開始 OK。
  uploaderAccountId Int?
  createdAt         DateTime  @default(now())
  expiresAt         DateTime?

  @@index([expiresAt])
}
